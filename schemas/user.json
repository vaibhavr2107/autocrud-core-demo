{
  "name": "user",
  "primaryKey": { 
    "name": "id", 
    "auto": true, 
    "strategy": "uuid", 
    "type": "string" 
  },
  "timestamps": true,
  "fields": {
    "id": { "type": "string", "required": true },
    "email": { "type": "string", "required": true },
    "name": { "type": "string", "required": false },
    "role": { "type": "string", "required": false, "default": "user" }
  }
}